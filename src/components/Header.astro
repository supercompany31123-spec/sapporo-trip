---
const BASE = '/sapporo-trip';
---

<header class="site-header">
  <div class="container header-inner">
    <a href={BASE} class="logo">ТюГт╣ї</a>
    <nav class="nav">
      <a href={BASE} class="nav-link">ждќжаЂ</a>
      <a href={`${BASE}/spots`} class="nav-link">ТЎ»ж╗ъ</a>
      <a href={`${BASE}/restaurants`} class="nav-link">уЙјжБЪ</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--secondary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    font-family: 'Noto Serif TC', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    letter-spacing: 0.05em;
  }

  .nav {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .nav {
      gap: 1rem;
    }
    .nav-link {
      font-size: 0.85rem;
    }
  }
</style>
