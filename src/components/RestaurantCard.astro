---
interface Props {
  slug: string;
  name: string;
  name_cn?: string;
  description: string;
  category: string;
  image: string;
  image_credit: string;
}

const { slug, name, name_cn, description, category, image, image_credit } = Astro.props;
const shortDesc = description.length > 80 ? description.slice(0, 80) + '…' : description;
const displayName = name_cn || name;
---

<a href={`/restaurants/${slug}`} class="restaurant-card">
  <div class="card-image">
    <img src={image} alt={name} loading="lazy" />
    <span class="category-tag">{category}</span>
  </div>
  <div class="card-body">
    <h3 class="card-title">{displayName}</h3>
    <p class="card-desc">{shortDesc}</p>
  </div>
</a>

<style>
  .restaurant-card {
    display: block;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .restaurant-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .restaurant-card:hover .card-image img {
    transform: scale(1.05);
  }

  .category-tag {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background-color: var(--accent);
    color: var(--secondary);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--text-dark);
  }

  .card-desc {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
  }
</style>
