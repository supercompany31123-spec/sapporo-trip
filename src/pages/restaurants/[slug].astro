---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const restaurants = await getCollection('restaurants');
  return restaurants.map(restaurant => ({
    params: { slug: restaurant.data.slug },
    props: { restaurant },
  }));
}

const { restaurant } = Astro.props;
const { Content } = await render(restaurant);
const displayName = restaurant.data.name_cn || restaurant.data.name;
const BASE = '/sapporo-trip';
---

<BaseLayout title={displayName} description={restaurant.data.description}>
  <Header />

  <main>
    <div class="restaurant-hero">
      <img src={`${BASE}${restaurant.data.image}`} alt={restaurant.data.name} />
      <div class="hero-overlay"></div>
      <div class="hero-text">
        <span class="category-tag">{restaurant.data.category}</span>
        <h1>{displayName}</h1>
        <p>{restaurant.data.description}</p>
      </div>
    </div>

    <div class="container">
      <div class="content-grid">
        <article class="markdown-content">
          <Content />
        </article>

        <aside class="info-sidebar">
          <div class="info-card">
            <h3>基本資訊</h3>
            <div class="info-item">
              <span class="info-label">地址</span>
              <span class="info-value">{restaurant.data.address}</span>
            </div>
            <div class="info-item">
              <span class="info-label">交通方式</span>
              <span class="info-value">{restaurant.data.transportation}</span>
            </div>
            {restaurant.data.opening_hours && (
              <div class="info-item">
                <span class="info-label">營業時間</span>
                <span class="info-value">{restaurant.data.opening_hours}</span>
              </div>
            )}
            {restaurant.data.price_range && (
              <div class="info-item">
                <span class="info-label">價位</span>
                <span class="info-value">{restaurant.data.price_range}</span>
              </div>
            )}
            {restaurant.data.reservation && (
              <div class="info-item">
                <span class="info-label">預約方式</span>
                <span class="info-value">{restaurant.data.reservation}</span>
              </div>
            )}
            {restaurant.data.official_url && (
              <div class="info-item">
                <span class="info-label">官方網站</span>
                <a href={restaurant.data.official_url} target="_blank" rel="noopener" class="info-link">
                  連結 →
                </a>
              </div>
            )}
          </div>

          <div class="tags-card">
            <h3>標籤</h3>
            <div class="tags">
              {restaurant.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>

          <div class="credit-card">
            <p class="credit">{restaurant.data.image_credit}</p>
          </div>
        </aside>
      </div>

      <!-- Google Maps -->
      <div class="map-section">
        <h2 class="map-title">📍 地圖位置</h2>
        <div class="map-embed">
          <iframe
            width="100%"
            height="350"
            style="border:0; border-radius: 12px;"
            loading="lazy"
            allowfullscreen
            src={`https://www.google.com/maps?q=${encodeURIComponent(restaurant.data.address)}&output=embed&hl=zh-TW`}
            title={`${displayName} 地圖`}
          ></iframe>
        </div>
        <div class="map-link">
          <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(restaurant.data.address)}`} target="_blank" rel="noopener" class="btn-map">
            在 Google Maps 中開啟 →
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .restaurant-hero {
    position: relative;
    height: 50vh;
    min-height: 400px;
    overflow: hidden;
  }

  .restaurant-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,46,0.8) 0%, rgba(26,26,46,0.2) 60%);
  }

  .hero-text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    color: white;
  }

  .category-tag {
    display: inline-block;
    background-color: var(--accent);
    color: var(--secondary);
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .hero-text h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .hero-text p {
    font-size: 1rem;
    opacity: 0.9;
    max-width: 700px;
    line-height: 1.6;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    padding: 3rem 0;
  }

  .markdown-content {
    font-size: 1rem;
    line-height: 1.8;
    color: #333;
  }

  .markdown-content :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
    color: var(--text-dark);
  }

  .markdown-content :global(h3) {
    font-size: 1.2rem;
    margin: 1.5rem 0 0.75rem;
    color: var(--text-dark);
  }

  .markdown-content :global(p) {
    margin-bottom: 1rem;
  }

  .markdown-content :global(ul), .markdown-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .markdown-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .markdown-content :global(a) {
    color: var(--primary);
  }

  .info-sidebar {
    position: sticky;
    top: 80px;
    height: fit-content;
  }

  .info-card, .tags-card, .credit-card {
    background: white;
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    margin-bottom: 1.5rem;
  }

  .info-card h3, .tags-card h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent);
  }

  .info-item {
    margin-bottom: 1rem;
  }

  .info-label {
    display: block;
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.25rem;
    font-weight: 500;
  }

  .info-value {
    font-size: 0.9rem;
    color: var(--text-dark);
  }

  .info-link {
    color: var(--primary);
    font-size: 0.9rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background-color: #f0ede8;
    color: #555;
    font-size: 0.8rem;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
  }

  .credit-card {
    background: #f9f9f9;
  }

  .credit {
    font-size: 0.75rem;
    color: #888;
  }

  .map-section {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }

  .map-title {
    font-size: 1.4rem;
    color: var(--text-dark);
    margin-bottom: 1.25rem;
  }

  .map-embed {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .map-link {
    margin-top: 1rem;
    text-align: right;
  }

  .btn-map {
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .btn-map:hover {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
    .info-sidebar {
      position: static;
    }
    .hero-text h1 {
      font-size: 1.8rem;
    }
  }
</style>
